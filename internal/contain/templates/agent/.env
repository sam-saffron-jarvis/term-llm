# term-llm agent: {{name}}

# term-llm version installed during Docker build.
# Use latest unless you intentionally need a specific release tag.
TERM_LLM_VERSION=latest

# Selected LLM provider for serve/jobs and first-boot config.yaml.
# Set to "skip" to leave provider selection to the container config/defaults.
TERM_LLM_PROVIDER={{provider}}

# API keys — set at least one provider key before starting.
ANTHROPIC_API_KEY={{anthropic_api_key}}
OPENAI_API_KEY={{openai_api_key}}
VENICE_API_KEY={{venice_api_key}}
GEMINI_API_KEY={{gemini_api_key}}
OPENROUTER_API_KEY={{openrouter_api_key}}
ZEN_API_KEY={{zen_api_key}}

# One-time first-boot ChatGPT OAuth bootstrap.
# If populated, entrypoint decodes this into /root/.config/term-llm/chatgpt_oauth.json
# on first boot only. Remove after first successful boot if desired.
TERM_LLM_CHATGPT_OAUTH_JSON_B64={{chatgpt_oauth_json_b64}}

# Web UI settings
WEB_PORT={{web_port}}
WEB_TOKEN={{web_token}}
WEB_BASE_PATH=/chat
